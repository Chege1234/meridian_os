# ============================================
# Meridian OS - Environment Variables
# ============================================
# Copy this file to .env.local and fill in values.
# Never commit .env.local to version control.
# ============================================

# ----- Supabase -----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ----- Database -----
DATABASE_URL=
# Connection URL for the Campus Marketplace external database.
# MUST be a read-only role with SELECT-only permission on the users table.
CAMPUS_MARKETPLACE_DATABASE_URL=


# ----- AI Providers -----
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
NVIDIA_API_KEY=
# 32-byte hexadecimal encryption key for database-backed API credentials (AES-256-GCM)
# Generate a new key with: openssl rand -hex 32
CREDENTIAL_ENCRYPTION_KEY=

# ----- Application -----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Meridian OS

# ----- Seeding -----
SEED_OWNER_USER_ID=

